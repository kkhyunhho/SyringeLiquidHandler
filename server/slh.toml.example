# SyringeLiquidHandler /v1 server config. Copy to slh.toml (gitignored) and
# edit for the bench. Ports accept a device path or a "VID:PID" hex string.
#
# This file lists EVERY section for reference. A real cell config keeps only
# ONE shape's sections: [pump]+[stage] for a pump+gantry cell (cell1–3), or
# [linear]+[balance] for a balance+linear cell (cell4). The server auto-detects
# the shape from the config (a [linear] table → balance+linear), so
# `python -m server --config <file>` alone is enough — see cell1/cell4.toml.example.

[pump]
port = "1A86:7523"   # SY-01B CH340 USB-serial (VID:PID), or e.g. "/dev/ttyUSB1"
address = 1
baud = 9600
syringe_uL = 125
init_force = 2        # 0/1/2 or 10..40 Z-init force code

[stage]
# Dispense cell (cell1–3) XZ gantry: 3 MKS SERVO57D via the ESP32 mks_motor
# driver. serial_x = FTDI serial of the X adapter; the other two adapters are
# the paired Z (auto-assigned, order-independent).
serial_x = "NTAM63XD"
z_coord_invert = true
# home_dir_z = 0       # flip 0<->1 to home off the opposite end
# home_dir_x = 0

# Balance+linear cell (cell4) sections — the MINAS A6 linear rail (codename
# `lmc`) over RS485 + the balance. Include these (and drop [pump]/[stage])
# for a cell4 config; their presence auto-selects the balance+linear shape.
[linear]
port = "/dev/ttyUSB0"

[balance]
# Omit `port` to auto-detect the Sartorius balance by vendor ID 0x24BC.
# port = "24BC:0010"
ambient = "very_unstable"   # very_stable | stable | unstable | very_unstable

[server]
host = "0.0.0.0"
port = 17054          # cell1–3 (dispense). For cell4 (weigh) use 17060.
log_level = "info"
