# cell4 (balance + linear) config. Copy to cell4.toml (gitignored).
#   python -m server --config server/cell4.toml          # real (cell auto-detected)

[linear]
# MINAS A6 over RS485 via Moxa UPort 1150. "VID:PID" is resolved at runtime
# (lmc.resolve_port) so it survives ttyUSBn renumbering; a /dev path also works.
port = "110A:1150"

[balance]
# Omit `port` to auto-detect the Sartorius balance by vendor ID 0x24BC.
# port = "24BC:0010"
ambient = "very_unstable"

[server]
host = "0.0.0.0"
port = 17060
log_level = "info"
